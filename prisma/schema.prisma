generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────

enum MaterialType {
  human_hair
  synthetic
}

enum CraftType {
  lace_front
  full_lace
  machine_made
  three_sixty_lace
  u_part
}

enum CurlPattern {
  straight
  body_wave
  deep_wave
  water_wave
  kinky_curly
  loose_wave
}

enum PriceMode {
  per_piece
  by_weight
}

enum QualityStatus {
  good
  defective
  refurbished
}

enum TxType {
  purchase_in      // 采购入库 (+)
  sale_out         // 销售出库 (-)
  return_in        // 客退回库 (良品+)
  return_defective // 客退回库 (次品区+)
  adjustment_pos   // 盘盈 (+)
  adjustment_neg   // 盘亏 (-)
  supplier_return  // 退给供应商 (-)
  scrap            // 报废 (-)
}

enum CustomerTier {
  retail
  vip
  vvip
  agent
}

enum OrderStatus {
  pending
  processing
  shipped
  completed
  cancelled
}

enum ShippingStatus {
  not_shipped
  partially_shipped
  shipped
  delivered
  returned
}

enum PaymentType {
  deposit          // 定金
  balance          // 尾款
  full_payment     // 全款
  refund           // 退款
}

// ── Models ─────────────────────────────────────────────────────

model Supplier {
  id         String   @id @default(cuid())
  name       String   @unique
  contact    String?
  country    String?
  deleted_at DateTime?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  batches    StockBatch[]

  @@map("suppliers")
  @@index([deleted_at])
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password_hash String
  role          UserRole @default(warehouse)
  deleted_at    DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  transactions  StockTransaction[]
  audit_logs    AuditLog[]

  @@map("users")
  @@index([deleted_at])
}

enum UserRole {
  admin
  manager
  warehouse
}

model Product {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  material    MaterialType
  craft       CraftType
  category    String?
  images      String[]     @default([])
  description String?
  price_mode  PriceMode    @default(per_piece)
  deleted_at  DateTime?
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  variants    Variant[]

  @@map("products")
  @@index([deleted_at])
}

model Variant {
  id              String        @id @default(cuid())
  product_id      String
  sku             String
  barcode         String?
  length          Decimal       @db.Decimal(5, 1)
  color           String
  curl            CurlPattern
  density         Int?          // 密度 150, 180...
  cap_size        CapSize?      @default(medium)
  shelf_no        String?
  images          String[]      @default([])
  
  // 库存字段 (缓存)
  stock           Int           @default(0)
  reserved_stock  Int           @default(0)   // 订单锁定
  defective_stock Int           @default(0)   // 次品存量
  
  // 价格
  cost_price      Decimal       @db.Decimal(12, 2)
  wholesale_price Decimal       @db.Decimal(12, 2)
  weight_grams    Decimal?      @db.Decimal(8, 2)
  
  deleted_at      DateTime?
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  product         Product       @relation(fields: [product_id], references: [id])
  tier_prices     TierPrice[]
  transactions    StockTransaction[]
  order_items     OrderItem[]

  @@map("variants")
  @@index([product_id])
  @@index([deleted_at])
}

enum CapSize {
  petite
  small
  medium
  large
  xlarge
}

model TierPrice {
  id         String       @id @default(cuid())
  variant_id String
  tier       CustomerTier
  price      Decimal      @db.Decimal(12, 2)
  updated_at DateTime     @updatedAt

  variant    Variant      @relation(fields: [variant_id], references: [id])

  @@unique([variant_id, tier])
  @@map("tier_prices")
}

model Customer {
  id             String       @id @default(cuid())
  display_name   String
  company_name   String?
  first_name     String?
  last_name      String?
  phone          String?
  email          String?
  country        String?      @default("US")
  tier           CustomerTier @default(retail)
  credit_days    Int          @default(0)
  credit_limit   Decimal?     @db.Decimal(12, 2)
  receivable_amt Decimal      @db.Decimal(12, 2) @default(0)
  deleted_at     DateTime?
  created_at     DateTime     @default(now())
  updated_at     DateTime @updatedAt
  addresses      Address[]
  orders         Order[]

  @@map("customers")
  @@index([display_name])
  @@index([deleted_at])
}

model Address {
  id             String   @id @default(cuid())
  customer_id    String
  label          String?
  recipient_name String?
  phone          String?
  address_line1  String
  address_line2  String?
  city           String
  state          String?
  zip            String?
  country        String   @default("US")
  is_default     Boolean  @default(false)
  deleted_at     DateTime?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  customer       Customer @relation(fields: [customer_id], references: [id])
  orders         Order[]

  @@map("addresses")
  @@index([customer_id])
  @@index([is_default])
  @@index([deleted_at])
}

model StockLocation {
  id          String   @id @default(cuid())
  code        String   // e.g., MAIN, DEFECTIVE
  name        String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("stock_locations")
}

model StockBatch {
  id          String   @id @default(cuid())
  batch_no    String   @unique
  supplier_id String
  note        String?
  created_at  DateTime @default(now())
  supplier    Supplier @relation(fields: [supplier_id], references: [id])
  transactions StockTransaction[]

  @@map("stock_batches")
}

model StockTransaction {
  id          String        @id @default(cuid())
  tx_no       String        @unique @default(uuid())
  variant_id  String
  location_id String?       // 来源或目标仓位
  batch_id    String?
  order_id    String?
  type        TxType
  quantity    Int           // 正值入库，负值出库
  quality     QualityStatus @default(good)
  operator_id String?
  note        String?
  created_at  DateTime      @default(now())

  variant     Variant       @relation(fields: [variant_id], references: [id])
  batch       StockBatch?   @relation(fields: [batch_id], references: [id])
  user        User?         @relation(fields: [operator_id], references: [id])
  order       Order?        @relation(fields: [order_id], references: [id])

  @@map("stock_transactions")
}

model Order {
  id                String         @id @default(cuid())
  order_no          String
  customer_id       String
  address_id        String?
  shipping_snapshot Json?
  status            OrderStatus    @default(pending)
  shipping_status   ShippingStatus @default(not_shipped)
  total_amount      Decimal        @db.Decimal(12, 2)
  paid_amount       Decimal        @db.Decimal(12, 2) @default(0)
  note              String?
  deleted_at        DateTime?
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt

  customer          Customer       @relation(fields: [customer_id], references: [id])
  address           Address?       @relation(fields: [address_id], references: [id])
  items             OrderItem[]
  payments          PaymentLog[]
  stock_txs         StockTransaction[]

  @@map("orders")
  @@index([order_no])
  @@index([deleted_at])
}

model OrderItem {
  id            String  @id @default(cuid())
  order_id      String
  variant_id    String
  quantity      Int
  unit_price    Decimal @db.Decimal(12, 2)
  weight_actual Decimal? @db.Decimal(8, 3)

  order         Order   @relation(fields: [order_id], references: [id], onDelete: Cascade)
  variant       Variant @relation(fields: [variant_id], references: [id])

  @@map("order_items")
}

model PaymentLog {
  id           String      @id @default(cuid())
  order_id     String
  amount       Decimal     @db.Decimal(12, 2)
  method       String?     // zelle, bank_transfer, cash
  payment_type PaymentType @default(full_payment)
  note         String?
  created_at   DateTime    @default(now())

  order        Order       @relation(fields: [order_id], references: [id])

  @@map("payment_logs")
}

model AuditLog {
  id          String   @id @default(cuid())
  table_name  String
  record_id   String
  action      String   // CREATE, UPDATE, DELETE
  old_data    Json?
  new_data    Json?
  operator_id String?
  created_at  DateTime @default(now())

  user        User?    @relation(fields: [operator_id], references: [id])

  @@map("audit_logs")
}

model TierSetting {
  id            String       @id @default(cuid())
  tier          CustomerTier @unique
  discount_rate Float        @default(0)   // 百分比格式 (e.g. 15 表示 15% off)
  description   String?
  updated_at    DateTime     @updatedAt

  @@map("tier_settings")
}
